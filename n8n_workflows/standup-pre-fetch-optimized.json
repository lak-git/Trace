    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=You must output ONLY a valid JSON object string. Do not include markdown blocks like ```json in your response.\n\nFill out this exact JSON structure using the data values provided:\n{\n  \"sprint_id\": \"{{ $json.sprint_id }}\",\n  \"participant_id\": \"{{ $json.participant_id }}\",\n  \"commits\": {{ JSON.stringify($json.commits || []) }},\n  \"blockers\": {{ JSON.stringify($json.blockers || []) }},\n  \"last_summary\": \"Write a 2-3 sentence progress summary here based on their commits and blockers.\"\n}",
        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3.1,
      "position": [
        672,
        0
      ],
      "id": "ca63612f-5179-4477-8e0a-d3b3bf5db63b",
      "name": "AI Agent"
    },
    {
      "parameters": {
        "jsCode": "// Access the nested data block from your prefetch response\nconst prefetchData = $input.item.json.data || {};\n\nconst contextRows = prefetchData.context_rows || [];\nconst compiledParticipants = prefetchData.compiled?.participants || [];\n\n// Map each context row into its own separate item for n8n's automatic looping\nreturn contextRows.map(row => {\n  \n  // Cross-reference compiled participants to pull display_name and commit status indicators\n  const participantDetail = compiledParticipants.find(\n    p => p.participant_id === row.participant_id\n  ) || {};\n\n  return {\n    json: {\n      sprint_id: row.sprint_id,\n      participant_id: row.participant_id,\n      display_name: participantDetail.display_name || \"Unknown\",\n      has_recent_commits: participantDetail.has_recent_commits || false,\n      commits: row.commits || [],\n      blockers: row.blockers || [],\n      last_summary: row.last_summary || \"\"\n    }\n  };\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
