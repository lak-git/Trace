{
  "name": "standup-pre-fetch-optimized",
  "nodes": [
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO public.standup_context (sprint_id, participant_id, commits, blockers, last_summary, compiled_at)\nVALUES ($1, $2, $3::jsonb, $4::jsonb, $5, NOW())\nON CONFLICT (sprint_id, participant_id) \nDO UPDATE SET \n  commits = EXCLUDED.commits,\n  blockers = EXCLUDED.blockers,\n  last_summary = EXCLUDED.last_summary,\n  compiled_at = NOW();",
        "options": {
          "queryReplacement": "={{ [   JSON.parse($json.output).sprint_id,   JSON.parse($json.output).participant_id,   JSON.stringify(JSON.parse($json.output).commits || []),   JSON.stringify(JSON.parse($json.output).blockers || []),   JSON.parse($json.output).last_summary ] }}"
        }
      },
