# .env.agent.example
# Copy to .env.agent and fill in real values.
# NEVER commit .env.agent to version control.

# --- Supabase / Database ---
# Project URL (Settings -> API). Used by the supabase-py SDK in the backend.
SUPABASE_URL=https://[project-ref].supabase.co
# Anon public key. NOT used by the backend; included so n8n's Supabase node
# can be wired without redeploys. Safe to expose in client contexts.
SUPABASE_ANON_KEY=your-anon-key
# Service role key (Settings -> API -> service_role). BACKEND ONLY.
# Bypasses RLS. Never expose to clients, n8n public webhooks, or commits.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Pooler connection string (Settings -> Database -> Connection pooling, port 5432).
# Used by n8n's Postgres node for direct SQL access in workflows.
SUPABASE_DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres

# --- Plane API ---
# Cloud: https://api.plane.so/api/v1
PLANE_API_BASE_URL=https://api.plane.so/api/v1
# API key — sent as X-API-Key header. Format: plane_api_<token>
PLANE_API_TOKEN=plane_api_your-token-here
# Workspace slug (from the URL: https://app.plane.so/<slug>/projects/)
PLANE_WORKSPACE_SLUG=your-workspace-slug
# Default project UUID
PLANE_PROJECT_ID=your-project-uuid

# --- Google AI Studio (Gemini - Student Credits) ---
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-3.1-pro

# --- Standup Scheduling ---
# Cron expression for pre-fetch workflow (default: weekdays at 8:45am)
STANDUP_CRON=45 8 * * 1-5
STANDUP_TIMEZONE=Asia/Colombo

# --- n8n Integration ---
# Shared secret for requests from n8n to the backend
AGENT_N8N_WEBHOOK_SECRET=generate-a-strong-random-secret

# --- GitHub ---
# Personal access token with repo scope
GITHUB_TOKEN=your-github-token
# Shared demo repo in owner/repo format
GITHUB_REPO=your-org/ai-scrum-master
